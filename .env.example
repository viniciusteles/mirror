# Minimal Mirror Mind configuration.
#
# Copy to `.env` and fill in your own values. For the full list of supported
# variables and overrides, see `.env.example.advanced` and the "Configuration"
# section of REFERENCE.md.

# --- Identity (CV4 user home) ---
# Pick one. MIRROR_USER resolves to ~/.mirror/<user>. MIRROR_HOME takes an
# explicit path. In production one of the two must be set.
MIRROR_USER=your-name
# MIRROR_HOME=~/.mirror/your-name

# --- API keys ---
# --- Memory Intelligence ---
# The reception classifier (LLM intent detection) is enabled by default.
# If you want to disable it and fall back to strict keyword matching, uncomment:
# MEMORY_RECEPTION=0

# OpenRouter is used for both embeddings and memory extraction.
# No separate OpenAI key is needed.
OPENROUTER_API_KEY=sk-or-...
