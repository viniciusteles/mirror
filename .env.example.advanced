# Mirror Mind — Canonical environment reference.
#
# This file lists every environment variable the memory system reads, with
# its default and its role. For a minimal starter template, see
# `.env.example`. For the operational doc, see the "Configuration" section
# of REFERENCE.md.
#
# `.env` is loaded automatically by `memory.config` when the process starts;
# values already set in the real environment take precedence (setdefault).


# ==========================================================================
# Identity — CV4 user home
# ==========================================================================

# In production, one of MIRROR_HOME or MIRROR_USER must be set. Both may be
# set only if they agree (MIRROR_HOME must end in the same user name).
# Tests and development can run without either.

# Explicit path to the user's mirror home. Takes precedence over MIRROR_USER.
# MIRROR_HOME=~/.mirror/vinicius

# Short user name. Resolves to ~/.mirror/<user>.
# MIRROR_USER=vinicius


# ==========================================================================
# API keys
# ==========================================================================

# OpenAI embeddings (text-embedding-3-small).
OPENAI_API_KEY=

# OpenRouter for extraction (Gemini Flash) and the multi-LLM consult command.
OPENROUTER_API_KEY=


# ==========================================================================
# Environment selection
# ==========================================================================

# One of: production, development, test. Default: production.
# Controls which database file is used and gates destructive operations
# (MemoryClient.reset is blocked in production).
# MEMORY_ENV=production


# ==========================================================================
# Path overrides — rarely set
# ==========================================================================
#
# Under CV4 these are all derived from the resolved MIRROR_HOME in production.
# Set them only when you need to override the default layout (e.g. keeping
# the DB on external storage, sharing backups across users, running tests
# against a custom directory).

# Runtime working directory. Holds the `mute` flag file and the
# `.bootstrap.lock` file. Defaults to MIRROR_HOME in production,
# ~/.mirror otherwise.
# MEMORY_DIR=

# Production-only runtime directory override. Rarely useful unless you run
# a separate production instance alongside development. Defaults to
# MEMORY_DIR.
# MEMORY_PROD_DIR=

# Full path to the SQLite database. Defaults to <MIRROR_HOME>/memory.db in
# production; <MEMORY_DIR>/memory_<env>.db otherwise.
# DB_PATH=

# Legacy alias for the backup directory. Prefer BACKUP_DIR. Defaults to
# <DB_PATH parent>/backups.
# DB_BACKUP_PATH=

# Directory for `python -m memory backup` output. Defaults to
# <MIRROR_HOME>/backups in production.
# BACKUP_DIR=

# Directory for markdown exports (week, etc.). Defaults to
# <MIRROR_HOME>/exports in production.
# EXPORT_DIR=


# ==========================================================================
# Runtime integrations
# ==========================================================================

# Source directory for `backfill_pi_sessions` (CV3 Pi runtime). Override
# when Pi session files live outside the default location, or when running
# a second mirror home on the same machine that should not pick up the
# primary user's Pi sessions. Default: ~/.pi/agent/sessions.
# PI_SESSIONS_DIR=

# Fallback session id used by conversation-logger CLIs when neither
# `--session-id` nor a hook payload is available. Almost never set by
# humans; reserved for scripted integrations that cannot inject a flag.
# MIRROR_SESSION_ID=


# ==========================================================================
# Variables set by external runtimes (do NOT set manually)
# ==========================================================================
#
# - CLAUDE_PROJECT_DIR is set by Claude Code when it invokes hooks.
# - Claude Code hook payloads carry `session_id` on stdin.
# - Pi's extension passes the session file path to the logger CLI.
